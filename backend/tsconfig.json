{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true, // Enables compatibility with CommonJS modules
    "skipLibCheck": true, // Skips type checking of declaration files
    "target": "ES2022", // Or "ES2021", "ES2020". Choose a recent stable version.
    "allowJs": true, // Allow JavaScript files to be compiled (useful if migrating)
    "resolveJsonModule": true, // Allows importing JSON files as modules
    "moduleDetection": "force", // Ensures files are treated as modules

    /* Strict Type-Checking Options: */
    "strict": true, // Enables all strict type-checking options
    // "noImplicitAny": true, // (Included in "strict") Raise error on expressions and declarations with an implied 'any' type.
    // "strictNullChecks": true, // (Included in "strict") When type checking, take `null` and `undefined` into account.
    // "strictFunctionTypes": true, // (Included in "strict") Enable stricter checking of function types.
    // "strictBindCallApply": true, // (Included in "strict") Enable stricter checking of 'bind', 'call', and 'apply' methods on functions.
    // "strictPropertyInitialization": true, // (Included in "strict") Ensure non-undefined class properties are initialized in the constructor.
    // "noImplicitThis": true, // (Included in "strict") Raise error on 'this' expressions with an implied 'any' type.
    // "useUnknownInCatchVariables": true, // (Recommended, "strict" sets this to false by default in older TS, true in TS 4.4+) Default `catch` clause variables as `unknown` instead of `any`.
    // "alwaysStrict": true, // (Included in "strict") Parse in strict mode and emit "use strict" for each source file.

    /* Module Resolution Options: */
    "module": "CommonJS", // Specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015', 'es2020', or 'ESNext'.
    "moduleResolution": "node", // Specifies module resolution strategy: 'node' (Node.js) or 'classic' (TypeScript pre-1.6).
    "baseUrl": "./src", // Base directory to resolve non-absolute module names.
    "paths": { // Optional: For path aliases, e.g., "@/*": ["*"]
      "@/*": ["*"]
      // "@config/*": ["config/*"],
      // "@services/*": ["core/services/*"],
      // "@utils/*": ["utils/*"]
    },
    // "rootDirs": [], // List of folders to be considered as roots for your project.
    // "typeRoots": [], // List of folders to include type definitions from.
    // "types": [], // Type declaration files to be included in compilation.

    /* Emit Options: */
    "outDir": "./dist", // Redirect output structure to the directory.
    "rootDir": "./src", // Specify the root directory of input files.
    "removeComments": true, // Do not emit comments to output.
    "emitDecoratorMetadata": true, // Enables experimental support for emitting type metadata for decorators. (Needed for TypeORM, InversifyJS, etc.)
    "experimentalDecorators": true, // Enables experimental support for ES7 decorators. (Needed for TypeORM, InversifyJS, etc.)
    // "noEmit": true, // Do not emit outputs. Useful if Babel or another transpiler handles the JS emit.
    // "declaration": true, // Generates corresponding '.d.ts' file.
    // "sourceMap": true, // Generates corresponding '.map' file for debugging.

    /* Interop Constraints */
    "forceConsistentCasingInFileNames": true, // Disallow inconsistently-cased references to the same file.

    /* Completeness */
    // "skipDefaultLibCheck": true, // (Redundant with skipLibCheck) Skip type checking of default library declaration files.

    /* Language and Environment */
    // "lib": ["ESNext"], // Specify library files to be included in the compilation.

    /* Output Formatting */
    // "pretty": true, // Stylize errors and messages using color and context. (Mostly for CLI)

    /* Advanced Options */
    "isolatedModules": true // Ensure that each file can be safely transpiled without relying on other imports (good practice for some bundlers/transpilers)
  },
  "include": [
    "src/**/*.ts", // Include all .ts files in the src directory
    "src/**/*.json" // If you use resolveJsonModule
  ],
  "exclude": [
    "node_modules", // Exclude node_modules
    "dist", // Exclude the output directory
    "src/**/*.spec.ts", // Exclude test files if they are in src
    "src/**/*.test.ts" // Exclude test files if they are in src
  ]
}